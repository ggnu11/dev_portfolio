generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  FRONTEND
  FRONTEND_LIBRARY
  ENV
  DESIGN
  ETC
}

enum ratio {
  PORTRAIT
  LANDSCAPE
  SQUARE
}

model experience {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(100)
  period    String   @db.VarChar(30)
  items     String[]
  links     Json[]
  is_active Boolean?
  sub_title String?  @db.VarChar(100)
  index     Int
  skill_ids Int[]
  category  String?  @db.VarChar(100)
}

model project {
  id         Int           @id
  title      String        @db.VarChar(100)
  sub_title  String        @db.VarChar(150)
  period     String        @db.VarChar(30)
  member     String        @db.VarChar(100)
  skills     String[]
  links      Json[]
  skill_ids  Int[]
  row_number Int?
  items      ProjectItem[]
}

model ProjectItem {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  content     String[]
  projectId   Int?
  project     project? @relation(fields: [projectId], references: [id])
  blobUrl     String?  @db.VarChar(255)
  row_number  Int?
  image_ratio ratio?
}

model intro {
  id      Int     @id @default(autoincrement())
  title   String  @db.VarChar(100)
  detail  String
  blobUrl String? @db.VarChar(255)
}

model blog {
  id          Int    @id @default(autoincrement())
  title       String @db.VarChar(150)
  date        String @db.VarChar(50)
  forwardLink String @db.VarChar(255)
  bgImageUrl  String @db.VarChar(255)
}

model skill {
  id       Int      @id @default(autoincrement())
  category Category
  items    String[]
  item     String   @db.VarChar(255)
  blobUrl  String   @db.VarChar(255)
}

model education {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(100)
  sub_title String   @db.VarChar(150)
  period    String   @db.VarChar(50)
  items     String[]
  category  String?  @db.VarChar(50)
}
